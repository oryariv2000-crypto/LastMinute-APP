# E2E test project credentials (a DEDICATED Supabase project, not production).
# Copy to e2e/.env.e2e and fill in. The service_role key is secret — e2e/.env.e2e
# is gitignored. Without these, authenticated E2E specs are skipped automatically.
#
# Two sets, both pointing at the SAME test project:
#   VITE_*  → consumed by the dev server (the browser app) so the UI talks to the
#             test project, not production. playwright.config injects these into
#             process.env, and Vite gives process.env vars top priority over .env.
#   E2E_*   → consumed by e2e/global-setup.js (service_role) to seed users/deals.
# The URL + anon key are identical in both sets; only the prefix differs.

VITE_SUPABASE_URL=https://your-test-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-test-anon-key

E2E_SUPABASE_URL=https://your-test-ref.supabase.co
E2E_SUPABASE_ANON_KEY=your-test-anon-key
E2E_SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key
# Which seeded user global-setup promotes to role 'admin' (gates the admin board
# via users.role = 'admin' in support.js + the support_tickets RLS).
E2E_ADMIN_EMAIL=oryariv2000@gmail.com

# Keep Turnstile OFF in e2e (empty) — the widget renders nothing without a key, so
# automated logins aren't slowed/challenged by the live Cloudflare script. Leaving
# this unset makes the dev server fall back to the real key in the main .env.
VITE_TURNSTILE_SITE_KEY=
